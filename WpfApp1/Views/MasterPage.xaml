<!-- Views/MasterPage.xaml -->
<Page x:Class="BearingProductionApp.Views.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель мастера" Height="650" Width="1100">

    <Page.Resources>
        <Style x:Key="ProductionRowStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Отлично">
                    <Setter Property="Background" Value="#90EE90"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Хорошо">
                    <Setter Property="Background" Value="#FFEB3B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Норма">
                    <Setter Property="Background" Value="#FFB6C1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#F5F5F5" Margin="5">
        <TabControl Margin="5">

            <!-- ВКЛАДКА 1: Типы подшипников -->
            <TabItem Header="Типы подшипников">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая панель -->
                    <Border Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Добавить/Редактировать" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TextBlock Text="Название:"/>
                            <TextBox x:Name="BearingNameTextBox" Height="25" Margin="0,3,0,8"/>

                            <TextBlock Text="Цена:"/>
                            <TextBox x:Name="BearingPriceTextBox" Height="25" Margin="0,3,0,10"/>

                            <WrapPanel>
                                <Button Content="Добавить" Click="AddBearing_Click" Width="90" Height="28" Margin="3"/>
                                <Button Content="Сохранить" Click="UpdateBearing_Click" Width="90" Height="28" Margin="3"/>
                                <Button Content="В архив" Click="ArchiveBearing_Click" Width="90" Height="28" Margin="3"/>
                            </WrapPanel>

                            <TextBlock Text="Поиск" FontWeight="Bold" Margin="0,15,0,5"/>
                            <TextBox x:Name="SearchBearingBox" TextChanged="SearchBearing_TextChanged" 
                                     Height="25" Margin="0,3,0,8"/>

                            <CheckBox x:Name="ShowArchivedCheckBox" Content="Показать архивные" 
                                     Checked="ShowArchived_Changed" Unchecked="ShowArchived_Changed" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <!-- Правая панель -->
                    <Border Grid.Column="1" Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="BearingSortCombo" SelectionChanged="BearingSort_Changed" Width="130" Height="25">
                                    <ComboBoxItem Content="По названию" IsSelected="True"/>
                                    <ComboBoxItem Content="По цене (возр)"/>
                                    <ComboBoxItem Content="По цене (убыв)"/>
                                    <ComboBoxItem Content="По ID"/>
                                </ComboBox>
                            </StackPanel>

                            <ListView x:Name="BearingsListView" Grid.Row="1" 
                                     ItemsSource="{Binding BearingTypes}"
                                     SelectedItem="{Binding SelectedBearingType}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding BearingTypeId}" Width="40"/>
                                        <GridViewColumn Header="Название" DisplayMemberBinding="{Binding TypeName}" Width="220"/>
                                        <GridViewColumn Header="Цена" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:F2} ₽}" HorizontalAlignment="Right"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Статус" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Активен"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                        <Setter Property="Text" Value="В архиве"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Excel" Click="ExportBearingsToExcel_Click" Width="80" Height="28" Margin="3"/>
                                <Button Content="Печать" Click="PrintBearings_Click" Width="80" Height="28" Margin="3"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 2: Производство -->
            <TabItem Header="Производство">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <Border Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <WrapPanel>
                            <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <DatePicker x:Name="DateFromPicker" SelectedDate="{Binding FilterDateFrom}" 
                                       Width="110" Height="25" Margin="0,0,8,0"/>

                            <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <DatePicker x:Name="DateToPicker" SelectedDate="{Binding FilterDateTo}" 
                                       Width="110" Height="25" Margin="0,0,8,0"/>

                            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="5,0,3,0"/>
                            <ComboBox x:Name="StatusFilterCombo" SelectionChanged="StatusFilter_Changed" Width="100" Height="25">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Отлично"/>
                                <ComboBoxItem Content="Хорошо"/>
                                <ComboBoxItem Content="Норма"/>
                            </ComboBox>

                            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0,3,0"/>
                            <TextBox x:Name="SearchProductionBox" TextChanged="SearchProduction_TextChanged" 
                                     Width="120" Height="23"/>

                            <Button Content="Сброс" Click="ResetFilters_Click" Margin="10,0,3,0" Width="60" Height="25"/>
                            <Button Content="Обновить" Click="RefreshProduction_Click" Margin="3,0,0,0" Width="60" Height="25"/>
                        </WrapPanel>
                    </Border>

                    <!-- Список -->
                    <Border Grid.Row="1" Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Группировка:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="ProductionGroupCombo" SelectionChanged="ProductionGroup_Changed" Width="120" Height="25">
                                    <ComboBoxItem Content="Без группировки" IsSelected="True"/>
                                    <ComboBoxItem Content="По статусу"/>
                                    <ComboBoxItem Content="По рабочему"/>
                                    <ComboBoxItem Content="По дате"/>
                                </ComboBox>

                                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                                <ComboBox x:Name="SortCombo" SelectionChanged="Sort_Changed" Width="130" Height="25">
                                    <ComboBoxItem Content="По дате (новые)" IsSelected="True"/>
                                    <ComboBoxItem Content="По дате (старые)"/>
                                    <ComboBoxItem Content="По количеству"/>
                                    <ComboBoxItem Content="По стоимости"/>
                                    <ComboBoxItem Content="По статусу"/>
                                </ComboBox>
                            </StackPanel>

                            <ListView x:Name="ProductionListView" Grid.Row="1"
                                     ItemsSource="{Binding ProductionRecords}"
                                     SelectedItem="{Binding SelectedProductionRecord}"
                                     ItemContainerStyle="{StaticResource ProductionRowStyle}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Дата" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ProductionDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Рабочий" DisplayMemberBinding="{Binding Users.Name}" Width="130"/>
                                        <GridViewColumn Header="Подшипник" DisplayMemberBinding="{Binding BearingTypes.TypeName}" Width="180"/>

                                        <GridViewColumn Header="Кол-во" Width="65">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Quantity}" HorizontalAlignment="Center" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Цена" Width="85">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BearingTypes.Price, StringFormat={}{0:F2}}" HorizontalAlignment="Right"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Стоимость" Width="100">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TotalCost, StringFormat={}{0:F2}}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                    </GridView>
                                </ListView.View>

                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Редактировать" Click="EditProduction_Click"/>
                                        <MenuItem Header="В архив" Click="ArchiveProduction_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Статус">
                                            <MenuItem Header="Отлично" Click="SetStatusExcellent_Click"/>
                                            <MenuItem Header="Хорошо" Click="SetStatusGood_Click"/>
                                            <MenuItem Header="Норма" Click="SetStatusNormal_Click"/>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="3,5,3,0">
                        <Button Content="Excel" Click="ExportProductionToExcel_Click" Width="80" Height="28" Margin="3"/>
                        <Button Content="PDF" Click="ExportProductionToPdf_Click" Width="80" Height="28" Margin="3"/>
                        <Button Content="Печать" Click="PrintProduction_Click" Width="80" Height="28" Margin="3"/>
                        <Button Content="Выход" Click="LogoutButton_Click" Width="80" Height="28" Margin="3"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 3: Отчеты -->
            <TabItem Header="Отчеты">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Меню -->
                    <Border Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="ОПЕРАТИВНЫЕ" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Button Content="Ежедневная" Click="DailyReport_Click" Height="30" Margin="0,3"/>
                            <Button Content="Текущий статус" Click="CurrentStatusReport_Click" Height="30" Margin="0,3"/>
                            <Button Content="По рабочему" Click="WorkerReport_Click" Height="30" Margin="0,3"/>

                            <TextBlock Text="АНАЛИТИЧЕСКИЕ" FontWeight="Bold" Margin="0,12,0,8"/>
                            <Button Content="Рейтинг" Click="RatingReport_Click" Height="30" Margin="0,3"/>
                            <Button Content="Сводка" Click="SummaryReport_Click" Height="30" Margin="0,3"/>
                        </StackPanel>
                    </Border>

                    <!-- Отчет -->
                    <Border Grid.Column="1" Background="White" Margin="3" Padding="8" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock x:Name="ReportTitleBlock" Text="Выберите отчет" FontSize="14" FontWeight="Bold"/>
                                <Button Content="Excel" Click="ExportReportExcel_Click" Margin="15,0,3,0" Width="70" Height="25"/>
                                <Button Content="PDF" Click="ExportReportPdf_Click" Margin="3,0,3,0" Width="70" Height="25"/>
                                <Button Content="Печать" Click="PrintReport_Click" Margin="3,0,0,0" Width="70" Height="25"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <DataGrid x:Name="ReportDataGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>