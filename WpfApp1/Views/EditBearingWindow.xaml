<Window x:Class="BearingProductionApp.Views.EditBearingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Редактирование подшипника" Height="300" Width="400" MinHeight="250" MinWidth="350" WindowStartupLocation="CenterScreen" d:DesignHeight="300" d:DesignWidth="400">
    <Grid Background="#F5F5F5" Margin="0,0,0,-44">
        <Border Background="White" Margin="20" Padding="20" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Редактирование подшипника" Style="{StaticResource HeaderText}" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Grid.Row="1" Text="Название:" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Margin="0,0,0,5"/>
                <TextBox Grid.Row="2" x:Name="EditTypeNameTextBox" Style="{StaticResource TextBoxStyle}" 
                         Margin="0,0,0,15" Width="300"/>

                <TextBlock Grid.Row="3" Text="Цена:" Style="{StaticResource LabelText}" 
                           VerticalAlignment="Center" Margin="0,0,0,5"/>
                <TextBox Grid.Row="4" x:Name="EditTypePriceTextBox" Style="{StaticResource TextBoxStyle}" 
                         Margin="0,0,0,15" Width="300" Text="{Binding Price, StringFormat={}{0:F2} ₽, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <Grid Grid.Row="5" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Сохранить" Click="SaveButton_Click" Style="{StaticResource ButtonStyle}" 
                            Margin="5,0,10,0" Width="100"/>
                    <Button Grid.Column="1" Content="Отмена" Click="CancelButton_Click" Style="{StaticResource ButtonStyle}" 
                            Margin="10,0,5,0" Width="100"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>